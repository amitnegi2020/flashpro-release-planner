# FlashPro Release Planner — Environment Variables
# Copy this file to .env.local and fill in your values
# Only needed when Auth Mode = "ThoughtWorks SSO (Okta)" in Config

# ── Okta Configuration ───────────────────────────────────────────────────────
# Phase 1 (local testing): Use your personal Okta Dev account credentials
# Phase 3+ (staging/prod): Use ThoughtWorks Okta credentials from PACE team

# Your Okta application Client ID
OKTA_CLIENT_ID=your-okta-client-id

# Your Okta application Client Secret
OKTA_CLIENT_SECRET=your-okta-client-secret

# Your Okta issuer URL (format: https://your-domain.okta.com/oauth2/default)
# For ThoughtWorks: https://thoughtworks.okta.com/oauth2/default
OKTA_ISSUER=https://your-domain.okta.com/oauth2/default

# NextAuth secret — any long random string (generate with: openssl rand -hex 32)
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ── Okta App Configuration ────────────────────────────────────────────────────
# In your Okta application settings, set:
#
# Sign-in redirect URIs:
#   http://localhost:3003/api/auth/callback/okta        (local dev)
#   https://your-domain.thoughtworks.net/api/auth/callback/okta  (production)
#
# Sign-out redirect URIs:
#   http://localhost:3003                               (local dev)
#   https://your-domain.thoughtworks.net               (production)
#
# Login initiated by: App Only
# Grant type: Authorization Code
# ──────────────────────────────────────────────────────────────────────────────
